{
  "name": "adb-tools-v1",
  "version": "3.3.3",
  "private": true,
  "main": "electron/main.js",
  "productName": "HardWare_TestTools",
  "description": "智能硬件 ADB 调试工具",
  "author": "zhaojia08",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "tsc && vite build",
    "clean": "if exist release rmdir /s /q release",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --win portable --publish never",
    "start": "npm run build && electron ."
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "lucide-react": "^1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "sharp": "^0.35.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "wait-on": "^9.0.5"
  },
  "build": {
    "icon": "build/icon.png",
    "appId": "com.adbtools.v1",
    "productName": "HardWare_TestTools",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/**/*",
      "package.json"
    ],
    "artifactName": "${productName}_${version}.${ext}",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "linux": {
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ]
    },
    "publish": null
  }
}
